# Copy this file to .env and fill in the values. .env is git-ignored.
#
# Only needed if you want the optional publish notification (Step 13 / Gate 14).
# If you leave these blank, the workflow still runs — the notifier just skips.
#
# scripts/notify_collection_publish.py reads this file. Its path is taken from
# the COLLECTION_OPTIMIZER_ENV environment variable, defaulting to ./.env.

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Telegram chat id to post to (a user id, group id, or channel id)
TELEGRAM_CHAT_ID=
